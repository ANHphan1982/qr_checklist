# =============================================================================
# QR Checklist — Root .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Claude Code — cấu hình local không cần commit
.claude/settings.local.json

# Secrets — KHÔNG BAO GIỜ commit
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ---------------------------------------------------------------------------
# Python (backend)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
ENV/
.pytest_cache/
.coverage
htmlcov/
*.log
instance/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Node.js (frontend)
# ---------------------------------------------------------------------------
node_modules/
dist/
.vite/
*.local

# ---------------------------------------------------------------------------
# QR Generator output (PNG files — tạo lại được)
# ---------------------------------------------------------------------------
qr-generator/output/

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Playwright E2E test artifacts (generated, not needed in repo)
# ---------------------------------------------------------------------------
frontend/playwright-report/
frontend/playwright-artifacts/
frontend/test-results/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/
