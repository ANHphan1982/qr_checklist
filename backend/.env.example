# =============================================================================
# backend/.env — Copy file này thành .env rồi điền giá trị thật
# KHÔNG commit file .env lên GitHub
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (PostgreSQL)
# Lấy tại: supabase.com → Project → Settings → Database → Connection String
# Chọn "URI" mode, copy toàn bộ chuỗi
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# Resend (Email)
# Đăng ký tại: resend.com (free 100 emails/ngày)
# Lấy API key tại: resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Địa chỉ gửi — cần verify domain hoặc dùng onboarding@resend.dev để test
EMAIL_FROM=checklist@yourdomain.com

# Địa chỉ nhận báo cáo (quản lý)
EMAIL_TO=manager@company.com

# ---------------------------------------------------------------------------
# App config
# ---------------------------------------------------------------------------
FLASK_ENV=production

# CORS — đặt đúng domain Vercel sau khi deploy frontend
# Ví dụ: https://qr-checklist.vercel.app
CORS_ORIGIN=https://your-app.vercel.app

# Port (Render tự set, không cần đổi)
PORT=5000

# ---------------------------------------------------------------------------
# Anti-fraud settings
# ---------------------------------------------------------------------------
# Chuỗi bí mật để ký Rotating QR token (thay bằng chuỗi ngẫu nhiên ≥ 32 ký tự)
# Tạo nhanh: python -c "import secrets; print(secrets.token_hex(32))"
QR_SECRET=CHANGE_ME_USE_PYTHON_SECRETS_TOKEN_HEX_32

# Chu kỳ đổi QR (giây). Mặc định 300 = 5 phút
QR_WINDOW_SECONDS=300

# true = chỉ chấp nhận Rotating QR (cần màn hình tại trạm)
# false = chấp nhận cả QR tĩnh in giấy (backward compatible)
REQUIRE_ROTATING_QR=false

# true = bắt buộc có GPS, từ chối nếu không có
REQUIRE_GPS=false

# Ngưỡng độ chính xác GPS tối đa (mét). Lớn hơn ngưỡng này → cảnh báo trong email
MAX_GPS_ACCURACY_METERS=200

# Rate limiting: tối đa N lần scan cùng trạm trong X phút từ cùng thiết bị
RATE_LIMIT_WINDOW_MINUTES=60
RATE_LIMIT_MAX_SCANS=3
